{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AlienAI",
  "version": "0.1.0",
  "identifier": "com.alienai.app",

  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": ""
  },

  "app": {
    "windows": [
      {
        "title": "AlienAI",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": { "csp": null }
  },

  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "appimage"],
    "icon": ["icons/icon.ico", "icons/icon.png"]
  },

  "plugins": {
    "updater": { "active": true }
  }
}
